@using WowEvolved.Models
@model WowEvolved.Models.ComparisonResult
@using WowEvolved.Services
@{
    ViewData["Title"] = "Análise — WoW Evolved";
    Layout = null;
    var langCode = ViewBag.Lang as string ?? "pt";
    var lang = langCode == "en" ? Lang.EN : Lang.PT;
    var backUrl = "/?lang=" + langCode;
    var p1 = Model.Player1;
    var p2 = Model.Player2;
    var winner = Model.Winner;
    var loser  = Model.Loser;
    bool p1wins = ReferenceEquals(winner, p1);
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Análise — WoW Evolved</title>
<link href="https://fonts.googleapis.com/css2?family=MedievalSharp&display=swap" rel="stylesheet">
<style>
:root{
  --wow-bg:#1a1209;--wow-bg2:#0e0b05;
  --wow-border:#8b7535;--wow-border2:#5a4d20;
  --wow-gold:#ffd100;--wow-gold2:#c8a800;--wow-gold3:#7a6510;
  --wow-text:#ffd880;--wow-text2:#c8a860;--wow-text3:#8a7040;
  --wow-red:#c41e3a;--wow-green:#1eff00;--wow-blue:#0070dd;
  --wow-purple:#a335ee;--wow-orange:#ff8000;--wow-grey:#9d9d9d;
  --wow-white:#ffffff;
  --panel-inner:#0d0a04;--inset-dark:#080603;
  --c-critical:#c41e3a;--c-high:#ff8000;--c-normal:#1eff00;
}
*{margin:0;padding:0;box-sizing:border-box}
body{
  background:var(--wow-bg2);color:var(--wow-text);
  font-family:'Times New Roman',Times,serif;min-height:100vh;
  background-image:radial-gradient(ellipse 80% 40% at 50% -5%,rgba(255,209,0,0.05) 0%,transparent 55%);
}
.container{max-width:1180px;margin:0 auto;padding:0 20px 60px;}

/* ── Nav ── */
.top-nav{
  display:flex;align-items:center;justify-content:space-between;
  padding:16px 0;border-bottom:2px solid var(--wow-border2);margin-bottom:28px;
}
.nav-logo{
  font-size:1.1rem;font-weight:bold;letter-spacing:0.1em;text-transform:uppercase;
  background:linear-gradient(180deg,#fff5a0,#ffd100,#7a6510);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.wow-back{
  padding:5px 16px;
  background:linear-gradient(180deg,#2a2000 0%,#1a1400 100%);
  border:1px solid var(--wow-border2);
  color:var(--wow-gold2);font-size:0.75rem;
  letter-spacing:0.2em;text-transform:uppercase;
  text-decoration:none;transition:all 0.15s;
}
.wow-back:hover{border-color:var(--wow-border);color:var(--wow-gold);}

/* ── Hero verdict ── */
.hero-verdict{text-align:center;margin-bottom:32px;}
.boss-tag{
  font-size:0.7rem;letter-spacing:0.4em;color:var(--wow-gold3);
  text-transform:uppercase;margin-bottom:10px;
}
.verdict-line{
  font-size:clamp(1.3rem,3.5vw,2rem);font-weight:bold;
  text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;
}
.vl-loser{color:var(--wow-red);text-shadow:0 0 16px rgba(196,30,58,0.5);}
.vl-winner{color:var(--wow-gold);text-shadow:0 0 16px rgba(255,209,0,0.5);}
.vl-sep{color:var(--wow-text3);font-size:0.7em;}
.diff-pill{
  display:inline-block;margin-top:10px;
  padding:4px 18px;
  background:rgba(196,30,58,0.18);border:1px solid var(--wow-red);
  color:#ff8888;font-size:0.78rem;letter-spacing:0.2em;
}

/* ── WoW divider ── */
.wow-div{display:flex;align-items:center;gap:0;margin:20px 0;}
.wow-div .l{flex:1;height:2px;background:linear-gradient(90deg,transparent,var(--wow-border2),var(--wow-border),var(--wow-border2),transparent);}
.wow-div .g{width:12px;height:12px;background:radial-gradient(circle at 35% 35%,#ffe066,#c8a800,#5a4500);transform:rotate(45deg);border:1px solid var(--wow-border);box-shadow:0 0 8px rgba(255,209,0,0.6);flex-shrink:0;}

/* ── Section title ── */
.sec-hdr{
  background:linear-gradient(90deg,#1a1200,#0e0900);
  border-left:3px solid var(--wow-gold2);
  border-top:1px solid var(--wow-border2);
  border-bottom:1px solid var(--wow-border2);
  padding:7px 16px;
  font-size:0.78rem;letter-spacing:0.3em;color:var(--wow-gold);
  text-transform:uppercase;font-weight:bold;
  margin-bottom:14px;display:flex;align-items:center;gap:8px;
}

/* ── Scoreboard ── */
.scoreboard{
  display:grid;grid-template-columns:1fr auto 1fr;
  gap:2px;background:var(--wow-border2);
  border:2px solid var(--wow-border);
  margin-bottom:28px;
}
.score-panel{
  background:var(--panel-inner);
  padding:22px 20px;
  position:relative;
}
.score-panel.is-winner::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,transparent,var(--wow-gold),transparent);
}
.score-panel.is-loser::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,transparent,var(--wow-red),transparent);
}
.crown-icon{font-size:1.2rem;display:block;margin-bottom:4px;}
.player-nm{
  font-size:1.15rem;font-weight:bold;letter-spacing:0.06em;
  text-transform:uppercase;margin-bottom:14px;
}
.is-winner .player-nm{color:var(--wow-gold);}
.is-loser  .player-nm{color:#e08080;}

.stat-tbl{width:100%;border-collapse:collapse;}
.stat-tbl tr{border-bottom:1px solid rgba(255,209,0,0.06);}
.stat-tbl tr:last-child{border-bottom:none;}
.stat-tbl td{padding:6px 4px;font-size:0.88rem;vertical-align:middle;}
.stat-lbl{color:var(--wow-text3);font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;}
.stat-val{text-align:right;font-weight:bold;}
.is-winner .stat-val{color:var(--wow-gold2);}
.is-loser  .stat-val{color:#e08080;}
.stat-bar-wrap{width:80px;text-align:right;}
.stat-bar{height:6px;border-radius:1px;display:inline-block;margin-top:4px;}
.is-winner .stat-bar{background:linear-gradient(90deg,var(--wow-gold3),var(--wow-gold));}
.is-loser  .stat-bar{background:linear-gradient(90deg,#6a0015,var(--wow-red));}
.eff-badge{
  display:inline-block;padding:2px 10px;
  font-size:0.8rem;font-weight:bold;margin-top:4px;
  border:1px solid;
}
.is-winner .eff-badge{color:var(--wow-gold);border-color:var(--wow-gold2);background:rgba(255,209,0,0.08);}
.is-loser  .eff-badge{color:#e08080;border-color:var(--wow-red);background:rgba(196,30,58,0.08);}

.score-vs{
  background:var(--panel-inner);
  display:flex;align-items:center;justify-content:center;min-width:50px;
}
.vs-lbl{font-size:1.1rem;font-weight:bold;color:var(--wow-red);text-shadow:0 0 12px rgba(196,30,58,0.6);}

/* ── Insights ── */
.insights-list{display:flex;flex-direction:column;gap:6px;margin-bottom:28px;}
.insight-row{
  background:var(--panel-inner);
  border:1px solid var(--wow-border2);
  border-left:4px solid var(--wow-border2);
  padding:10px 14px;
  font-size:0.9rem;line-height:1.55;
  transition:border-color 0.15s;
}
.insight-row:hover{border-left-color:var(--wow-gold2);}

/* ── Suggestions ── */
.sug-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:10px;margin-bottom:28px;}
.sug-card{
  background:var(--panel-inner);
  border:1px solid var(--wow-border2);
  position:relative;overflow:hidden;
}
.sug-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.sug-card.prio-critical::before{background:linear-gradient(90deg,var(--wow-red),#ff4060);}
.sug-card.prio-high::before{background:linear-gradient(90deg,var(--wow-orange),#ffb040);}
.sug-card.prio-normal::before{background:linear-gradient(90deg,var(--wow-blue),#40a0ff);}

.sug-header{
  padding:10px 14px 6px;
  display:flex;align-items:center;gap:8px;justify-content:space-between;
  border-bottom:1px solid rgba(255,209,0,0.07);
}
.sug-skill{font-size:0.88rem;font-weight:bold;color:var(--wow-text);}
.sug-cat{
  font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;
  padding:2px 8px;border:1px solid;border-radius:1px;
}
.prio-critical .sug-cat{color:var(--wow-red);border-color:var(--wow-red);background:rgba(196,30,58,0.12);}
.prio-high     .sug-cat{color:var(--wow-orange);border-color:var(--wow-orange);background:rgba(255,128,0,0.1);}
.prio-normal   .sug-cat{color:var(--wow-blue);border-color:var(--wow-blue);background:rgba(0,112,221,0.1);}

.sug-body{padding:10px 14px;}
.sug-row{display:flex;gap:6px;margin-bottom:7px;font-size:0.84rem;line-height:1.5;}
.sug-icon{flex-shrink:0;width:16px;text-align:center;margin-top:2px;}
.sug-txt b{color:var(--wow-text2);}
.sug-dps{
  margin-top:8px;padding:5px 10px;
  background:rgba(255,209,0,0.04);border:1px solid rgba(255,209,0,0.12);
  font-size:0.78rem;display:flex;align-items:center;justify-content:space-between;
}
.sug-dps-lbl{color:var(--wow-text3);letter-spacing:0.12em;text-transform:uppercase;font-size:0.68rem;}
.sug-dps-val{color:var(--wow-gold);font-weight:bold;}

/* ── Skill table ── */
.tbl-wrap{
  background:var(--panel-inner);
  border:1px solid var(--wow-border2);
  overflow-x:auto;
  margin-bottom:28px;
}
.tbl-legend{
  display:flex;gap:20px;padding:8px 14px;
  border-bottom:1px solid rgba(255,209,0,0.08);
}
.leg-item{display:flex;align-items:center;gap:6px;font-size:0.68rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--wow-text3);}
.leg-dot{width:10px;height:10px;}
.dot-loser{background:var(--wow-red);}
.dot-winner{background:var(--wow-gold);}

.skill-tbl{width:100%;border-collapse:collapse;min-width:700px;}
.skill-tbl th{
  background:linear-gradient(180deg,#1c1508,#0e0900);
  font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;
  color:var(--wow-gold3);font-weight:bold;
  padding:8px 10px;text-align:left;border-bottom:2px solid var(--wow-border2);
}
.skill-tbl th.r{text-align:right;}
.skill-tbl td{padding:7px 10px;font-size:0.84rem;border-bottom:1px solid rgba(255,209,0,0.04);}
.skill-tbl tr:last-child td{border-bottom:none;}
.skill-tbl tr:hover td{background:rgba(255,209,0,0.02);}

.sk-name{color:var(--wow-text);font-weight:bold;}
.sk-note{font-size:0.72rem;color:var(--wow-text3);margin-top:2px;font-weight:normal;}

.prio-ind{
  display:inline-block;width:8px;height:8px;border-radius:50%;
  margin-right:6px;vertical-align:middle;flex-shrink:0;
}
.pi-critical{background:var(--wow-red);box-shadow:0 0 5px var(--wow-red);}
.pi-high{background:var(--wow-orange);box-shadow:0 0 5px var(--wow-orange);}
.pi-normal{background:var(--wow-blue);}

.td-r{text-align:right;font-variant-numeric:tabular-nums;}
.col-p1{color:#e08080;}
.col-p2{color:var(--wow-gold2);}
.col-up{color:var(--wow-green);}
.col-dn{color:var(--wow-red);}

.bar-cell{width:100px;}
.bar-wrap{display:flex;gap:1px;height:12px;background:rgba(0,0,0,0.4);border-radius:1px;overflow:hidden;}
.bw{border-radius:1px;}
.bw-loser{background:rgba(196,30,58,0.65);}
.bw-winner{background:rgba(255,209,0,0.65);}

.lost-cell{text-align:right;font-variant-numeric:tabular-nums;color:var(--wow-orange);font-weight:bold;}

/* ── Crit / Uptime mini cols ── */
.crit-good{color:var(--wow-green);}
.crit-bad{color:var(--wow-red);}
.crit-same{color:var(--wow-text3);}

/* ── Top10 tables ── */
.dual-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:28px;}
.mini-tbl-wrap{background:var(--panel-inner);border:1px solid var(--wow-border2);overflow:hidden;}
.mini-tbl-hdr{
  padding:7px 12px;font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--wow-gold);font-weight:bold;
  background:linear-gradient(90deg,#1a1200,#0e0900);
  border-bottom:1px solid var(--wow-border2);
}
.mini-tbl{width:100%;border-collapse:collapse;}
.mini-tbl td{padding:6px 10px;font-size:0.82rem;border-bottom:1px solid rgba(255,209,0,0.04);}
.mini-tbl tr:last-child td{border-bottom:none;}
.mini-tbl .sk{color:var(--wow-text);}
.mini-tbl .dv1{text-align:right;color:#e08080;font-weight:bold;}
.mini-tbl .dv2{text-align:right;color:var(--wow-gold2);font-weight:bold;}
.mini-tbl .pct{text-align:right;color:var(--wow-text3);font-size:0.75rem;}

/* ── Trophy ── */
.trophy-box{
  background:linear-gradient(180deg,#1a1200,#0e0900);
  border:2px solid var(--wow-border);
  text-align:center;padding:28px;position:relative;
  margin-bottom:28px;
}
.trophy-box::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,var(--wow-gold),transparent);}
.trophy-ico{font-size:2.8rem;display:block;margin-bottom:10px;filter:drop-shadow(0 0 12px rgba(255,209,0,0.6));}
.trophy-lbl{font-size:0.7rem;letter-spacing:0.35em;color:var(--wow-gold3);text-transform:uppercase;margin-bottom:4px;}
.trophy-nm{font-size:1.8rem;font-weight:bold;color:var(--wow-gold);text-shadow:0 0 18px rgba(255,209,0,0.5);text-transform:uppercase;letter-spacing:0.08em;}

/* ── Est DPS summary bar ── */
.dps-loss-bar{
  background:var(--panel-inner);border:1px solid var(--wow-border2);
  padding:14px 18px;margin-bottom:28px;
  display:flex;align-items:center;gap:16px;flex-wrap:wrap;
}
.dpl-icon{font-size:1.3rem;}
.dpl-text{flex:1;min-width:200px;}
.dpl-title{font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--wow-gold);font-weight:bold;margin-bottom:2px;}
.dpl-val{font-size:1.1rem;color:var(--wow-orange);font-weight:bold;}
.dpl-sub{font-size:0.78rem;color:var(--wow-text3);}

footer{text-align:center;padding:22px 0 0;font-size:0.7rem;letter-spacing:0.12em;color:var(--wow-text3);border-top:1px solid var(--wow-border2);}
footer a{color:var(--wow-gold3);text-decoration:none;}
footer a:hover{color:var(--wow-gold);}

@@media(max-width:700px){
  .scoreboard{grid-template-columns:1fr;}
  .score-vs{padding:10px;}
  .dual-grid{grid-template-columns:1fr;}
  .sug-grid{grid-template-columns:1fr;}
}
</style>
</head>
<body>
<div class="container">

  <!-- Nav -->
  @await Html.PartialAsync("_LangSwitcher")
  <nav class="top-nav">
    <div class="nav-logo">⚔ WoW Evolved</div>
    <a href="@backUrl" class="wow-back">@LocalizationService.UI.BackBtn(lang)</a>
  </nav>

  <!-- Hero -->
  <div class="hero-verdict">
    <div class="boss-tag">@LocalizationService.UI.BossTag(lang)</div>
    <div class="verdict-line">
      <span class="vl-loser">@loser.PlayerName</span>
      <span class="vl-sep"> @LocalizationService.UI.LostLabel(lang) </span>
      <span class="vl-winner">@winner.PlayerName</span>
    </div>
    <div class="diff-pill">▼ @Model.DiffPercent.ToString("F1")% @LocalizationService.UI.DiffLess(lang)</div>
  </div>

  <div class="wow-div"><div class="l"></div><div class="g"></div><div class="l"></div></div>

  <!-- Scoreboard -->
  <div class="scoreboard">
    <div class="score-panel @(p1wins ? "is-winner" : "is-loser")">
      @if (p1wins){ <span class="crown-icon">👑</span> }
      <div class="player-nm">@p1.PlayerName</div>
        @if(p1.ActiveSpec.ClassName != "Unknown"){<div style="font-family:'Cinzel',serif;font-size:.62rem;letter-spacing:.18em;color:var(--wow-gold3);text-transform:uppercase;margin-bottom:10px;">@p1.ActiveSpec.ClassName — @p1.ActiveSpec.SpecName (@p1.ActiveSpec.Archetype)</div>}else{<div style="font-size:.72rem;color:var(--wow-text3);margin-bottom:10px;font-style:italic;">Classe não detectada — análise universal</div>}
      <table class="stat-tbl">
        <tr><td class="stat-lbl">@LocalizationService.UI.TotalDmg(lang)</td><td class="stat-val">@p1.TotalDamage.ToString("N0")</td></tr>
        <tr><td class="stat-lbl">@LocalizationService.UI.TotalDps(lang)</td><td class="stat-val">@p1.TotalDps.ToString("N0")</td></tr>
        <tr><td class="stat-lbl">@LocalizationService.UI.FightDur(lang)</td><td class="stat-val">~@p1.FightDuration.ToString("F0")s</td></tr>
        <tr><td class="stat-lbl">@LocalizationService.UI.AvgCrit(lang)</td><td class="stat-val">@p1.AvgCritPct.ToString("F1")%</td></tr>
        <tr><td class="stat-lbl">@LocalizationService.UI.AvgUptime(lang)</td><td class="stat-val">@p1.AvgUptimePct.ToString("F1")%</td></tr>
        <tr><td class="stat-lbl">@LocalizationService.UI.AvgMiss(lang)</td><td class="stat-val">@p1.AvgMissPct.ToString("F1")%</td></tr>
        <tr><td class="stat-lbl">@LocalizationService.UI.Abilities(lang)</td><td class="stat-val">@p1.Records.Count</td></tr>
        <tr>
          <td class="stat-lbl">@LocalizationService.UI.EffScore(lang)</td>
          <td class="stat-val"><span class="eff-badge">@p1.EfficiencyScore.ToString("F1") / 100</span></td>
        </tr>
      </table>
    </div>
    <div class="score-vs"><div class="vs-lbl">VS</div></div>
    <div class="score-panel @(!p1wins ? "is-winner" : "is-loser")">
      @if (!p1wins){ <span class="crown-icon">👑</span> }
      <div class="player-nm">@p2.PlayerName</div>
        @if(p2.ActiveSpec.ClassName != "Unknown"){<div style="font-family:'Cinzel',serif;font-size:.62rem;letter-spacing:.18em;color:var(--wow-gold3);text-transform:uppercase;margin-bottom:10px;">@p2.ActiveSpec.ClassName — @p2.ActiveSpec.SpecName (@p2.ActiveSpec.Archetype)</div>}else{<div style="font-size:.72rem;color:var(--wow-text3);margin-bottom:10px;font-style:italic;">Classe não detectada — análise universal</div>}
      <table class="stat-tbl">
        <tr><td class="stat-lbl">Dano Total</td><td class="stat-val">@p2.TotalDamage.ToString("N0")</td></tr>
        <tr><td class="stat-lbl">DPS Total</td><td class="stat-val">@p2.TotalDps.ToString("N0")</td></tr>
        <tr><td class="stat-lbl">Duração Fight</td><td class="stat-val">~@p2.FightDuration.ToString("F0")s</td></tr>
        <tr><td class="stat-lbl">Crit Médio</td><td class="stat-val">@p2.AvgCritPct.ToString("F1")%</td></tr>
        <tr><td class="stat-lbl">Uptime Médio</td><td class="stat-val">@p2.AvgUptimePct.ToString("F1")%</td></tr>
        <tr><td class="stat-lbl">Miss Médio</td><td class="stat-val">@p2.AvgMissPct.ToString("F1")%</td></tr>
        <tr><td class="stat-lbl">Habilidades</td><td class="stat-val">@p2.Records.Count</td></tr>
        <tr>
          <td class="stat-lbl">Score Eficiência</td>
          <td class="stat-val"><span class="eff-badge">@p2.EfficiencyScore.ToString("F1") / 100</span></td>
        </tr>
      </table>
    </div>
  </div>

  <!-- DPS lost summary -->
  @{
    double totalLost = Model.SkillDiffs.Sum(d => {
      bool loserP1 = ReferenceEquals(loser, p1);
      double lDps = loserP1 ? d.P1Dps : d.P2Dps;
      double wDps = loserP1 ? d.P2Dps : d.P1Dps;
      return Math.Max(0, wDps - lDps);
    });
  }
  <div class="dps-loss-bar">
    <span class="dpl-icon">⚠️</span>
    <div class="dpl-text">
      <div class="dpl-title">@LocalizationService.UI.DpsLostTitle(lang) — @loser.PlayerName</div>
      <div class="dpl-val">~@totalLost.ToString("N0") DPS</div>
      <div class="dpl-sub">@LocalizationService.UI.DpsLostSub(lang, loser.PlayerName, winner.PlayerName)</div>
    </div>
  </div>

  <!-- Insights -->
  @if (Model.Insights.Any())
  {
    <div class="sec-hdr">@LocalizationService.UI.DiagTitle(lang)</div>
    <div class="insights-list">
      @foreach (var ins in Model.Insights)
      {
        <div class="insight-row">@ins</div>
      }
    </div>
  }

  <!-- Improvement suggestions -->
  @if (Model.Suggestions.Any())
  {
    <div class="sec-hdr">
      @LocalizationService.UI.ImpTitle(lang, loser.PlayerName)
      <span style="font-size:0.6rem;letter-spacing:0.15em;color:var(--wow-text3);margin-left:auto;">
        @LocalizationService.UI.PrioLegend(lang)
      </span>
    </div>
    <div class="sug-grid">
      @foreach (var s in Model.Suggestions)
      {
        <div class="sug-card prio-@s.Priority">
          <div class="sug-header">
            <span class="sug-skill">
              <span class="prio-ind pi-@s.Priority"></span>@s.Skill
            </span>
            <span class="sug-cat">@s.Category</span>
          </div>
          <div class="sug-body">
            <div class="sug-row">
              <span class="sug-icon">⚡</span>
              <span class="sug-txt"><b>@LocalizationService.UI.What(lang):</b> @s.What</span>
            </div>
            <div class="sug-row">
              <span class="sug-icon">📖</span>
              <span class="sug-txt"><b>@LocalizationService.UI.Why(lang):</b> @s.Why</span>
            </div>
            <div class="sug-row">
              <span class="sug-icon">🕐</span>
              <span class="sug-txt"><b>@LocalizationService.UI.When(lang):</b> @s.When</span>
            </div>
            @if (s.DpsGainEst > 0)
            {
              <div class="sug-dps">
                <span class="sug-dps-lbl">@LocalizationService.UI.DpsGainLabel(lang)</span>
                <span class="sug-dps-val">~+@s.DpsGainEst.ToString("N0") DPS</span>
              </div>
            }
          </div>
        </div>
      }
    </div>
  }

  <!-- Full skill comparison table -->
  @{
    double maxD = Model.SkillDiffs.Any() ? Model.SkillDiffs.Max(d => Math.Max(d.P1Dps, d.P2Dps)) : 1;
    bool loserP1g = ReferenceEquals(loser, p1);
  }
  <div class="sec-hdr">@LocalizationService.UI.SkillCmpTitle(lang)</div>
  <div class="tbl-wrap">
    <div class="tbl-legend">
      <div class="leg-item"><div class="leg-dot dot-loser"></div> @loser.PlayerName</div>
      <div class="leg-item"><div class="leg-dot dot-winner"></div> @winner.PlayerName</div>
    </div>
    <table class="skill-tbl">
      <thead>
        <tr>
          <th style="min-width:180px">@LocalizationService.UI.Ability(lang)</th>
          <th class="r">@p1.PlayerName DPS</th>
          <th class="r">@p2.PlayerName DPS</th>
          <th class="r">Crit @p1.PlayerName</th>
          <th class="r">Crit @p2.PlayerName</th>
          <th class="r">Uptime @p1.PlayerName</th>
          <th class="r">Uptime @p2.PlayerName</th>
          <th class="r">@LocalizationService.UI.Diff(lang)</th>
          <th class="r">@LocalizationService.UI.DpsLostCol(lang)</th>
          <th class="r">@LocalizationService.UI.Distribution(lang)</th>
        </tr>
      </thead>
      <tbody>
      @foreach (var d in Model.SkillDiffs.Take(35))
      {
        var lDps = loserP1g ? d.P1Dps : d.P2Dps;
        var wDps = loserP1g ? d.P2Dps : d.P1Dps;
        bool p2higher = d.DiffDps > 0;
        int bw1 = maxD > 0 ? (int)(d.P1Dps / maxD * 100) : 0;
        int bw2 = maxD > 0 ? (int)(d.P2Dps / maxD * 100) : 0;
        double lost = Math.Max(0, wDps - lDps);

        string critCls(double lc, double wc) => wc - lc > 5 ? "crit-good" : lc - wc > 5 ? "crit-bad" : "crit-same";
        <tr>
          <td>
            <div class="sk-name">
              <span class="prio-ind pi-@d.Priority"></span>@d.Name
            </div>
            @if (!string.IsNullOrEmpty(d.RotationNote)){
              <div class="sk-note">↳ @d.RotationNote</div>
            }
          </td>
          <td class="td-r col-p1">@d.P1Dps.ToString("N0")</td>
          <td class="td-r col-p2">@d.P2Dps.ToString("N0")</td>
          <td class="td-r @(p1wins ? critCls(d.P2Crit,d.P1Crit) : critCls(d.P1Crit,d.P2Crit))">@d.P1Crit.ToString("F1")%</td>
          <td class="td-r @(p1wins ? critCls(d.P1Crit,d.P2Crit) : critCls(d.P2Crit,d.P1Crit))">@d.P2Crit.ToString("F1")%</td>
          <td class="td-r @(p1wins ? critCls(d.P2Uptime,d.P1Uptime) : critCls(d.P1Uptime,d.P2Uptime))">@d.P1Uptime.ToString("F1")%</td>
          <td class="td-r @(p1wins ? critCls(d.P1Uptime,d.P2Uptime) : critCls(d.P2Uptime,d.P1Uptime))">@d.P2Uptime.ToString("F1")%</td>
          <td class="td-r @(p2higher ? "col-up" : "col-dn")">
            @(p2higher ? "▲" : "▼") @Math.Abs(d.DiffDps).ToString("N0")
          </td>
          <td class="lost-cell">@(lost > 0 ? "~" + lost.ToString("N0") : "—")</td>
          <td class="bar-cell">
            <div class="bar-wrap">
              <div class="bw bw-loser" style="width:@(loserP1g ? bw1 : bw2)%"></div>
              <div class="bw bw-winner" style="width:@(loserP1g ? bw2 : bw1)%"></div>
            </div>
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>

  <!-- Top 10 each -->
  <div class="sec-hdr">@LocalizationService.UI.Top10Title(lang)</div>
  <div class="dual-grid">
    <div class="mini-tbl-wrap">
      <div class="mini-tbl-hdr">@p1.PlayerName</div>
      <table class="mini-tbl">
        @foreach (var r in p1.Records.OrderByDescending(r => r.DpsNum).Take(10))
        {
          <tr>
            <td class="sk">@r.Name</td>
            <td class="dv1">@r.DpsNum.ToString("N0")</td>
            <td class="pct">@r.Pct.ToString("F2")%</td>
          </tr>
        }
      </table>
    </div>
    <div class="mini-tbl-wrap">
      <div class="mini-tbl-hdr">@p2.PlayerName</div>
      <table class="mini-tbl">
        @foreach (var r in p2.Records.OrderByDescending(r => r.DpsNum).Take(10))
        {
          <tr>
            <td class="sk">@r.Name</td>
            <td class="dv2">@r.DpsNum.ToString("N0")</td>
            <td class="pct">@r.Pct.ToString("F2")%</td>
          </tr>
        }
      </table>
    </div>
  </div>


  <!-- Phase notes (custom JSON only) -->
  @if (Model.Loser.ActiveSpec.IsCustom && Model.Loser.ActiveSpec.CustomPhaseNotes.Any())
  {
    <div class="sec-hdr">🗺️ Notas de Fase — @Model.Loser.ActiveSpec.SpecName (JSON customizado)</div>
    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:28px">
      @foreach (var ph in Model.Loser.ActiveSpec.CustomPhaseNotes)
      {
        <div style="background:var(--panel-inner);border:1px solid var(--wow-border2);border-left:4px solid var(--wow-gold3);padding:10px 16px;display:flex;gap:12px;align-items:baseline">
          <span style="font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--wow-gold2);white-space:nowrap;min-width:100px">@ph.Phase</span>
          <span style="font-size:.88rem;color:var(--wow-text2);line-height:1.5">@ph.Note</span>
        </div>
      }
    </div>
  }

  <!-- Priority list (custom JSON only) -->
  @if (Model.Loser.ActiveSpec.IsCustom && Model.Loser.ActiveSpec.CustomPriorityList.Any())
  {
    <div class="sec-hdr">📋 Priority List Customizada — @Model.Loser.ActiveSpec.SpecName</div>
    <div class="tbl-wrap" style="margin-bottom:28px">
      <table class="skill-tbl">
        <thead><tr><th style="width:40px">#</th><th>Habilidade</th><th>Nota de Rotação</th><th class="r" style="width:80px">Core?</th></tr></thead>
        <tbody>
        @{ int pi=0; }
        @foreach (var e in Model.Loser.ActiveSpec.CustomPriorityList)
        {
          pi++;
          bool isCore = e.IsCoreRotation;
          <tr>
            <td style="font-family:'Cinzel',serif;font-weight:700;color:@(pi<=2?"var(--wow-red)":pi<=4?"var(--wow-orange)":"var(--wow-text3)")">@pi</td>
            <td class="sk-name">@e.Skill</td>
            <td style="font-size:.82rem;color:var(--wow-text2)">@e.Note</td>
            <td class="r"><span style="font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;padding:2px 7px;border:1px solid;@(isCore?"color:var(--wow-green);border-color:var(--wow-green);background:rgba(30,255,0,.06)":"color:var(--wow-text3);border-color:var(--wow-border2)")">@(isCore?"Core":"Filler")</span></td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  }

  <!-- Trophy -->
  <div class="trophy-box">
    <span class="trophy-ico">🏆</span>
    <div class="trophy-lbl">@LocalizationService.UI.WinnerTitle(lang)</div>
    <div class="trophy-nm">@winner.PlayerName</div>
  </div>

  <footer><a href="/">@LocalizationService.UI.BackBtn(lang)</a> &nbsp;|&nbsp; WoW Evolved Combat Analytics</footer>
</div>
</body>
</html>
